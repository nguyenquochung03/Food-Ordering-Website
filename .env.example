# Copy file này thành .env và điền giá trị thực tế
# KHÔNG COMMIT file .env chứa giá trị thật lên git

# Backend
JWT_SECRET=random_secret_here
STRIPE_SECRET_KEY=sk_test_your_stripe_key
DB=mongodb+srv://username:password@cluster0.mongodb.net/food-delivery
HOST=smtp.gmail.com
